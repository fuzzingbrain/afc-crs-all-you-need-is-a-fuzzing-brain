  # lint:
  #   name: Code Quality
  #   runs-on: ubuntu-latest
  #
  #   steps:
  #   - name: Checkout code
  #     uses: actions/checkout@v4
  #
  #   - name: Set up Python
  #     uses: actions/setup-python@v5
  #     with:
  #       python-version: '3.10'
  #
  #   - name: Set up Go
  #     uses: actions/setup-go@v5
  #     with:
  #       go-version: '1.21'
  #
  #   - name: Install Python linting tools
  #     run: |
  #       pip install flake8 black
  #
  #   - name: Run Python linters
  #     run: |
  #       cd crs/strategy
  #       flake8 common core strategies --max-line-length=120 --extend-ignore=E203,W503
  #
  #   - name: Run Go linters
  #     run: |
  #       cd crs && go vet ./...
  #       cd ../static-analysis && go vet ./...

  # ============================================================================
  # Summary Job (required for branch protection)
  # ============================================================================
  ci-success:
    name: CI Success
    runs-on: ubuntu-latest
    needs: [go-tests]
    if: always()

    steps:
    - name: Check test results
      run: |
        echo "Go Tests: ${{ needs.go-tests.result }}"

        if [[ "${{ needs.go-tests.result }}" != "success" ]]; then
          echo "ERROR: Go tests failed!"
          exit 1
        fi

        echo "All tests passed successfully!"
