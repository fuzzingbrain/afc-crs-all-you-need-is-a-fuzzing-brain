# ============================================
# Competition API Configuration
# ============================================
COMPETITION_API_KEY_ID=your-competition-api-key-id
COMPETITION_API_KEY_TOKEN=your-competition-api-key-token
COMPETITION_API_ENDPOINT=http://localhost:7081

# ============================================
# CRS API Configuration
# ============================================
CRS_KEY_ID=your-crs-key-id
CRS_KEY_TOKEN=your-crs-key-token

# ============================================
# OpenTelemetry Configuration
# ============================================
OTEL_SDK_DISABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT="https://otel.your-endpoint.tech"
OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic your-base64-encoded-credentials"
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ============================================
# Fuzzing Configuration
# ============================================
ADVANCED_FUZZER_TEST=1

# Detect timeout as crash (default: 0/disabled)
# When enabled, libFuzzer timeouts are treated as crashes
DETECT_TIMEOUT_CRASH=0

# Detect memory leaks as crashes (default: 0/disabled)
# When enabled, LeakSanitizer errors are treated as crashes
# Note: Memory leaks are typically not exploitable security issues
# Enable only for comprehensive code quality testing
DETECT_LEAK_AS_CRASH=0

# ============================================
# AI Model API Keys
# ============================================
# Primary keys - Add at least one valid API key
OPENAI_API_KEY=sk-proj-your-actual-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-actual-anthropic-key-here
GEMINI_API_KEY=your-actual-gemini-key-here
XAI_API_KEY=xai-your-actual-xai-key-here

# Backup keys (optional)
OPENAI_API_KEY_R1=your-openai-backup-key
OPENAI_API_KEY0=your-openai-backup-key-2
ANTHROPIC_API_KEY_R1=your-anthropic-backup-key
ANTHROPIC_API_KEY0=your-anthropic-backup-key-2
GEMINI_API_KEY_R1=your-gemini-backup-key
GEMINI_API_KEY0=your-gemini-backup-key-2

# ============================================
# GitHub Configuration
# ============================================
GITHUB_TOKEN=your-github-token

# ============================================
# Strategy Configuration
# ============================================

# Base configuration
STRATEGY_BASE_DIR=/app/strategy
STRATEGY_NEW_DIR=jeff

# ---------------------------------------------
# POV Strategy Patterns
# ---------------------------------------------
# Control which strategy files are matched by glob patterns
# Delta mode: uses xs0_delta.py
# Full mode: uses as0_full.py
STRATEGY_POV_ADVANCED_DELTA_PATTERN="xs0_delta.py"
STRATEGY_POV_ADVANCED_FULL_PATTERN="as0_full.py"

# ---------------------------------------------
# Patch Strategy Patterns
# ---------------------------------------------
# Delta mode: uses patch0_delta.py
# Full mode: uses patch0_full.py
STRATEGY_PATCH_DELTA_PATTERN="patch0_delta.py"
STRATEGY_PATCH_FULL_PATTERN="patch0_full.py"

# ---------------------------------------------
# POV Strategy Selection
# ---------------------------------------------
# Values:
#   - empty or "all": run all matching strategies
#   - "none": skip all strategies
#   - specific filename: run only that strategy
#
# Examples:
#   STRATEGY_POV_SELECTED_BASIC=""                    # Run all basic strategies
#   STRATEGY_POV_SELECTED_BASIC="all"                 # Run all basic strategies
#   STRATEGY_POV_SELECTED_BASIC="xs0_delta_new.py"    # Run only xs0_delta_new.py
#   STRATEGY_POV_SELECTED_BASIC="none"                # Skip all basic strategies

STRATEGY_POV_SELECTED_BASIC=""
STRATEGY_POV_SELECTED_ADVANCED=""

# ---------------------------------------------
# Patch Strategy Selection
# ---------------------------------------------
# Values: same as POV strategy selection
#
# Examples:
#   STRATEGY_PATCH_SELECTED=""                   # Run all patch strategies
#   STRATEGY_PATCH_SELECTED="patch0_delta.py"    # Run only patch0_delta.py
#   STRATEGY_PATCH_SELECTED="none"               # Skip all patch strategies

STRATEGY_PATCH_SELECTED=""
STRATEGY_XPATCH_SELECTED="none"

# ---------------------------------------------
# Patching Phase Control
# ---------------------------------------------
# Set to false to only do POV generation without patching
# Set to true to enable patching after POV is found
STRATEGY_ENABLE_PATCHING=true

# ============================================
# Common Usage Examples
# ============================================

# Example 1: Only test POV generation (no patching)
# STRATEGY_POV_SELECTED_BASIC="xs0_delta_new.py"
# STRATEGY_POV_SELECTED_ADVANCED="none"
# STRATEGY_ENABLE_PATCHING=false

# Example 2: Test specific POV and patch strategies
# STRATEGY_POV_SELECTED_BASIC="xs0_delta_new.py"
# STRATEGY_POV_SELECTED_ADVANCED="as0_delta_new.py"
# STRATEGY_PATCH_SELECTED="patch0_delta.py"
# STRATEGY_XPATCH_SELECTED="none"
# STRATEGY_ENABLE_PATCHING=true

# Example 3: Run all strategies (default behavior)
# STRATEGY_POV_SELECTED_BASIC="all"
# STRATEGY_POV_SELECTED_ADVANCED="all"
# STRATEGY_PATCH_SELECTED="all"
# STRATEGY_XPATCH_SELECTED="all"
# STRATEGY_ENABLE_PATCHING=true

# Example 4: Only run advanced POV strategies
# STRATEGY_POV_SELECTED_BASIC="none"
# STRATEGY_POV_SELECTED_ADVANCED="all"
# STRATEGY_ENABLE_PATCHING=false

# ============================================
# Fuzzing Build Configuration
# ============================================

# ---------------------------------------------
# Sanitizer Selection
# ---------------------------------------------
# Comma-separated list of sanitizers to build fuzzers with
# Available sanitizers: address, memory, undefined, thread
#
# Examples:
#   FUZZER_SANITIZERS="address"                         # Build only address
#   FUZZER_SANITIZERS="address,memory,undefined"        # Build multiple
#   FUZZER_SANITIZERS=""                                # Use project.yaml defaults
#
# Important Notes:
#   - If set, this overrides the sanitizers list in project.yaml
#   - Coverage is ALWAYS built for C/C++ projects (mandatory for control flow analysis)
#   - Coverage is NOT listed here - it's built automatically and separately
#   - For comprehensive bug detection, use: address,memory,undefined
FUZZER_SANITIZERS="address"

# Preferred sanitizer for fuzzing (when multiple sanitizers are built)
# This is used when a specific fuzzer needs to be selected
# Default: address
FUZZER_PREFERRED_SANITIZER="address"

# ---------------------------------------------
# Fuzzer Selection
# ---------------------------------------------
# Specify which fuzzer(s) to use from the built fuzzers
#
# Values:
#   - empty: auto-discover and use all fuzzers
#   - fuzzer name: use specific fuzzer (e.g., "avif_decode_fuzzer")
#   - pattern: use glob pattern (e.g., "avif_*_fuzzer")
#   - comma-separated: use multiple fuzzers (e.g., "fuzzer1,fuzzer2")
#
# Examples:
#   FUZZER_SELECTED=""                      # Auto-discover all fuzzers
#   FUZZER_SELECTED="avif_decode_fuzzer"    # Use specific fuzzer
#   FUZZER_SELECTED="avif_*"                # Use pattern matching
FUZZER_SELECTED=""

# Fuzzer discovery mode
# Values:
#   - "auto": automatically discover executable fuzzers
#   - "config": only use fuzzers specified in FUZZER_SELECTED
# Default: auto
FUZZER_DISCOVERY_MODE="auto"

# ---------------------------------------------
# Per-Fuzzer Timeout
# ---------------------------------------------
# Time budget in minutes for each individual fuzzer
# When running multiple fuzzers, each gets its own fresh timeout
# Default: 60 (1 hour per fuzzer)
#
# Examples:
#   FUZZER_PER_FUZZER_TIMEOUT_MINUTES=60    # 1 hour per fuzzer (default)
#   FUZZER_PER_FUZZER_TIMEOUT_MINUTES=30    # 30 minutes per fuzzer
#   FUZZER_PER_FUZZER_TIMEOUT_MINUTES=120   # 2 hours per fuzzer
FUZZER_PER_FUZZER_TIMEOUT_MINUTES=60
