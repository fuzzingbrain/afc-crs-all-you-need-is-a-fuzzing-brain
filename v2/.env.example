# LLM API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional: override workspace path (default: $PWD/workspace)
# FUZZINGBRAIN_HOST_WORKSPACE=/absolute/path/to/workspace

# --- Cost & safety limits (all optional) ---
# Hard LLM spend cap in USD; the run stops when exceeded. Strongly recommended.
# Usually set via FuzzingBrain.sh --budget; this is the env equivalent.
# FUZZINGBRAIN_BUDGET_LIMIT=20

# Per-call LLM timeout in seconds (default 120). Bounds a single hung call.
# LLM_TIMEOUT=120

# Retries (same model, exponential backoff) on transient LLM errors before
# falling back to another model (default 2). Failed attempts are not billed.
# LLM_MAX_RETRIES=2

# --- Optional features ---
# Run the introspector static-analysis pass (off by default; agents navigate
# code via tools). Slower builds, more failure surface; opt in if you want it.
# FUZZINGBRAIN_ENABLE_STATIC_ANALYSIS=false

# Disable prompt (KV) caching of stable prompt prefixes. Caching is on by
# default and cuts input-token cost; set to 1 only if a provider misbehaves.
# FUZZINGBRAIN_DISABLE_PROMPT_CACHE=0
